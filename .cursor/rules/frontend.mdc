  Activity, 
  ActivityCreate, 
  ActivityUpdate,
  SourceConfig,
  SourceType 
} from '@/client/types.gen'

interface ActivityFormData {
  title: string
  content?: string
  source_type: SourceType
}

const createActivity = (data: ActivityFormData): ActivityCreate => {
  return {
    ...data,
    occurred_at: new Date().toISOString(),
  }
}

// ❌ 错误：手动定义类型
interface Activity {  // 不要重复定义
  id: number
  title: string
  // ...
}
```

