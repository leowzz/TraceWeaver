        <p>{activity.content}</p>
      </CardContent>
    </Card>
  )
}
```

## TanStack Query 使用规范

### 数据获取

使用自动生成的客户端和 TanStack Query：

```typescript
import { useQuery, useMutation, useQueryClient } from '@tanstack/react-query'
import { ActivitiesService, ActivityCreate } from '@/client'

// ✅ 正确：使用 useQuery
export const useActivities = (userId: string) => {
  return useQuery({
    queryKey: ['activities', userId],
    queryFn: () => ActivitiesService.listActivities({ userId }),
    staleTime: 1000 * 60 * 5,  // 5分钟
  })
}

// ✅ 正确：使用 useMutation
export const useCreateActivity = () => {
  const queryClient = useQueryClient()
  
  return useMutation({
    mutationFn: (data: ActivityCreate) => 
      ActivitiesService.createActivity({ requestBody: data }),
    onSuccess: () => {
      // 刷新活动列表
      queryClient.invalidateQueries({ queryKey: ['activities'] })
    },
  })
}

// 在组件中使用
const ActivityListPage: FC = () => {
  const { data, isLoading, error } = useActivities('user-id')
  const createMutation = useCreateActivity()
  
  if (isLoading) return <Loading />
  if (error) return <Error message={error.message} />
  
  return (
    <div>
      {data?.map(activity => (
        <ActivityCard key={activity.id} activity={activity} />
      ))}
    </div>
  )
}
```

### Query Key 命名规范

使用数组形式，层级清晰：

```typescript
// ✅ 正确：结构化 Query Key
['activities']  // 所有活动
['activities', userId]  // 特定用户的活动
['activities', userId, { filter: 'git' }]  // 带过滤条件
['activities', activityId]  // 单个活动
['reports', 'daily', date]  // 日报

// ❌ 错误：字符串拼接
['activities-' + userId]  // 不利于缓存管理
['activity_detail_' + id]  // 难以批量失效
```

### 数据更新策略

```typescript
// 乐观更新
const updateMutation = useMutation({
  mutationFn: (data: ActivityUpdate) => 
    ActivitiesService.updateActivity({ id: data.id, requestBody: data }),
  onMutate: async (newData) => {
    // 取消正在进行的查询
    await queryClient.cancelQueries({ queryKey: ['activities', newData.id] })
    
    // 保存旧数据
    const previousData = queryClient.getQueryData(['activities', newData.id])
    
    // 乐观更新
    queryClient.setQueryData(['activities', newData.id], newData)
    
    return { previousData }
  },
  onError: (err, newData, context) => {
    // 回滚
    if (context?.previousData) {
      queryClient.setQueryData(['activities', newData.id], context.previousData)
    }
  },
  onSettled: (data) => {
    // 重新获取数据
    queryClient.invalidateQueries({ queryKey: ['activities', data?.id] })
  },
})
```

## TanStack Router 使用规范

### 路由定义

```typescript
// routes/activities.tsx
import { createFileRoute } from '@tanstack/react-router'
import { ActivitiesService } from '@/client'

// 定义路由参数类型
interface ActivitySearchParams {
  filter?: 'git' | 'siyuan' | 'dayflow'
  date?: string
}

export const Route = createFileRoute('/activities')({
  component: ActivitiesPage,
  
  // 类型安全的搜索参数
  validateSearch: (search: Record<string, unknown>): ActivitySearchParams => ({
    filter: search.filter as ActivitySearchParams['filter'],
    date: search.date as string,
  }),
  
  // 数据预加载
  loader: async ({ context }) => {
    const activities = await ActivitiesService.listActivities({
      userId: context.auth.userId,
    })
    return { activities }
  },
})

// 组件中使用
function ActivitiesPage() {
  const { activities } = Route.useLoaderData()
  const { filter, date } = Route.useSearch()
  const navigate = Route.useNavigate()
  
  return (
    <div>
      <button onClick={() => navigate({ search: { filter: 'git' } })}>
        筛选 Git 活动
      </button>
      <ActivityList activities={activities} />
    </div>
  )
}
```

### 路由导航

```typescript
import { useNavigate } from '@tanstack/react-router'

// ✅ 正确：类型安全的导航
const navigate = useNavigate()

navigate({ to: '/activities' })
navigate({ to: '/activities/$id', params: { id: '123' } })
navigate({ to: '/activities', search: { filter: 'git' } })
navigate({ to: '..', }) // 返回上级

