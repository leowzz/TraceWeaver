```typescript
import { createFileRoute } from '@tanstack/react-router'

export const Route = createFileRoute('/activities')({
  component: ActivitiesPage,
  validateSearch: (search): ActivitySearchParams => ({ ... }),
  loader: async ({ context }) => { ... },
})
```

